# Choose one API target and uncomment it.
# If none is uncommented, app auto-resolves URL from Expo host IP.

# Android emulator:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api
# API_BASE_URL=http://10.0.2.2:8000/api

# iOS simulator / web on same machine:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api
# API_BASE_URL=http://localhost:8000/api

# Real device on same Wi-Fi:
# EXPO_PUBLIC_API_BASE_URL=http://<YOUR_PC_IP>:8000/api
# API_BASE_URL=http://<YOUR_PC_IP>:8000/api

# PayPal public config
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_ENVIRONMENT=sandbox

# Optional
ANALYTICS_KEY=
SENTRY_DSN=
